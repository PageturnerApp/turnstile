# Turnstile - Self-hosted download provider bridge
# Part of the Pageturner project: https://github.com/pageturner-app/turnstile
# Licensed under AGPL v3 - https://www.gnu.org/licenses/agpl-3.0.html

# Prowlarr
# Base URL for your Prowlarr instance. Include any reverse-proxy base path.
PROWLARR_URL=http://localhost:9696

# Prowlarr API key from Settings -> General.
PROWLARR_API_KEY=

# Torrent Client
# Accepted values: qbittorrent, deluge, transmission, rtorrent
TORRENT_CLIENT=qbittorrent

# Web/API URL for the selected torrent client. Include the port and any reverse-proxy base path.
# qBittorrent example: http://localhost:8080
# Deluge Web JSON-RPC examples: http://localhost:8112, http://127.0.0.1:13355, https://host.example:443/deluge
# Transmission example: http://localhost:9091
# rTorrent XML-RPC-over-HTTP example: http://localhost/RPC2
TORRENT_CLIENT_URL=http://localhost:8080

# Username for qBittorrent, Transmission, or protected rTorrent endpoints.
# Deluge Web uses the password field below; this username is kept for seedbox setups.
TORRENT_CLIENT_USER=admin

# Password for the selected torrent client.
TORRENT_CLIENT_PASS=adminpass

# Turnstile
# Global root folder for all downloadable files. Per-key paths must live inside this root.
DOWNLOADS_PATH=/home/user/downloads

# Public URL clients use to call Turnstile. Include any HTTPS reverse-proxy base path.
BRIDGE_URL=http://your-seedbox-ip:7878

# HTTP port for Turnstile.
PORT=7878

# Auto-generated - do not edit manually
# JSON-stringified array of API key objects managed by the UI.
API_KEYS=[]

# Bcrypt hash for the UI password, created by /ui/setup on first run.
UI_PASSWORD_HASH=
